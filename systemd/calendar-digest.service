[Unit]
Description=Calendar Digest — weekly email summary
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/jamie/calendar-digest
ExecStart=/home/jamie/.local/bin/uv run calendar_digest.py
StandardOutput=journal
StandardError=journal
Restart=on-failure
RestartSec=60
StartLimitIntervalSec=300
StartLimitBurst=3
